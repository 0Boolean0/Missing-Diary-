PORT=5000
# Supabase PostgreSQL connection string. Get it from Supabase Dashboard -> Project Settings -> Database.
# Recommended for backend servers: use the Pooler URI, then replace [YOUR-PASSWORD].
DATABASE_URL=postgresql://postgres.your_project_ref:YOUR_SUPABASE_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
JWT_SECRET=change_this_to_a_long_random_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
FRONTEND_URL=http://localhost:5173
