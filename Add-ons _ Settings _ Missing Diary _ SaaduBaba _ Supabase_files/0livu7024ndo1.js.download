            'schema', r.schema,
            'name', r.name,
            'type', r.type,
            'comment', r.comment,
            'rls_enabled', r.rls_enabled
          )
          order by ${l}
        ), '[]'::jsonb),
        'count', coalesce(min(r.count), 0)
