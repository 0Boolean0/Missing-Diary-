        create or replace function pg_temp.explain_query(query text) returns jsonb
        language plpgsql
        as $$
        declare
            explain_result jsonb;
            prepared_statement_name text := 'query_to_explain';
            explain_plan_statement text;
            n_args int;
        begin
            -- Remove comment lines (its common that they contain semicolons)
            query := trim(
                regexp_replace(
                    regexp_replace(
                        regexp_replace(query,'\\/\\*.+\\*\\/', '', 'g'),
                    '--[^\\r\\n]*', ' ', 'g'),
                '\\s+', ' ', 'g')
            );
      
            -- Remove trailing semicolon
            query := regexp_replace(query, ';\\s*$', '');

            -- Disallow multiple statements
            if query ilike '%;%' then
                raise exception 'Query must not contain a semicolon';
            end if;
        
            -- Hack to support PostgREST because the prepared statement for args incorrectly defaults to text
            query := replace(query, 'WITH pgrst_payload AS (SELECT $1 AS json_data)', 
                                    'WITH pgrst_payload AS (SELECT $1::json AS json_data)');
        
            -- Create a prepared statement for the given query
            deallocate all;
            execute format('prepare %I as %s', prepared_statement_name, query);
        
            -- Detect how many arguments are present in the prepared statement
            n_args = (
                select
                    coalesce(array_length(parameter_types, 1), 0)
                from
                    pg_prepared_statements
                where
                    name = prepared_statement_name
                limit
                    1
            );
        
            -- Create a SQL statement that can be executed to collect the explain plan
            explain_plan_statement = format(
                'set local plan_cache_mode = force_generic_plan; explain (format json) execute %I%s',
                prepared_statement_name,
                case
                    when n_args = 0 then ''
                    else format(
                        '(%s)', array_to_string(array_fill('null'::text, array[n_args]), ',')
                    )
                end
            );
        
            -- Execute the explain plan statement and get the result
            execute explain_plan_statement into explain_result;
        
            -- Clean up the prepared statement
            deallocate all;
        
            -- Return the explain result
            return explain_result;
        end;
        $$;

        select pg_temp.explain_query('${r}') as plans;
      `}),i=(s=n,a=[],!function e(t){null!==t&&"object"==typeof t&&("Index Name"in t&&a.push(t["Index Name"]),Object.values(t).forEach(t=>e(t)))}(s),a);if(i.length<=0)return[];let{result:o}=await (0,T.executeSql)({projectRef:e,connectionString:t,queryKey:["involved-indexes-names"],sql:`select schemaname as schema, tablename as table, indexname as name from pg_indexes where indexname in (${i.map(e=>`'${e}'`).join(", ")});`});return o}catch(e){return[]}}var $=e.i(635494),k=e.i(10429),F=e.i(967052);let D=({selectedRow:e,columnName:T,suggestedSelectQuery:D,prefetchedIndexAdvisorResult:z,onClose:M})=>{let{data:L}=(0,$.useSelectedProjectQuery)(),[O,W]=(0,n.useState)(!1),[K,U]=(0,n.useState)(!1),B=(0,F.useTrack)(),[H,G]=(0,n.useState)(!1),{data:Y,isSuccess:J,isPending:Z,isError:V,error:X}=(({projectRef:e,connectionString:t,query:r},{enabled:s=!0,...a}={})=>{let n=(r??"").trim().toLowerCase(),i=n.startsWith("select")||n.startsWith("with pgrst_source")||n.startsWith("with pgrst_payload");return(0,P.useQuery)({queryKey:E.databaseKeys.indexesFromQuery(e,r),queryFn:()=>Q({projectRef:e,connectionString:t,query:r}),retry:!1,enabled:s&&void 0!==e&&void 0!==r&&i,...a})})({projectRef:L?.ref,connectionString:L?.connectionString,query:e?.query}),{data:ee,isPending:et}=(0,I.useDatabaseExtensionsQuery)({projectRef:L?.ref,connectionString:L?.connectionString}),{isIndexAdvisorEnabled:er}=(0,A.useIndexAdvisorStatus)(),es=void 0!==z,{data:ea,error:en,refetch:ei,isError:eo,isSuccess:el,isLoading:ed}=(0,R.useGetIndexAdvisorResult)({projectRef:L?.ref,connectionString:L?.connectionString,query:e?.query},{enabled:er&&!es}),ec=es?z:ea,eu=es||el,em=!es&&ed,{index_statements:ep,startup_cost_after:ex,startup_cost_before:eh,total_cost_after:ef,total_cost_before:eg}=ec??{index_statements:[],total_cost_after:0,total_cost_before:0},e_=(0,j.hasIndexRecommendations)(ec,eu);(0,j.calculateImprovement)(eg,ef);let ey=(0,b.useIndexInvalidation)();(0,n.useEffect)(()=>{em||H||(B("index_advisor_tab_clicked",{hasR