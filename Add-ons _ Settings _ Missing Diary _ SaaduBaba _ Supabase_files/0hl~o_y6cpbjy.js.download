  select * from index_advisor(tq.query)
) ia on true;`),{result:h}=await (0,u.executeSql)({projectRef:e,connectionString:t,sql:x}),f=(h||[]).filter(e=>e.index_statements&&e.index_statements.length>0).map(e=>{let t=(0,c.filterProtectedSchemaIndexStatements)(e.index_statements);if(0===t.length)return null;let r=e.total_cost_before>0?(e.total_cost_before-e.total_cost_after)/e.total_cost_before*100:0;return{query:e.query,calls:e.calls,total_time:e.total_time,mean_time:e.mean_time,index_statements:t,startup_cost_before:e.startup_cost_before,startup_cost_after:e.startup_cost_after,total_cost_before:e.total_cost_before,total_cost_after:e.total_cost_after,improvement_percentage:Math.round(100*r)/100}}).filter(e=>null!==e),g=function(e){let t=new Set;for(let r of e){let e=r.match(/USING\s+\w+\s*\(([^)]+)\)/i);e&&e[1].split(",").forEach(e=>{let r=m(e);r&&/^[a-z_][a-z0-9_$]*$/i.test(r)&&t.add(r)})}return Array.from(t)}(f.flatMap(e=>e.index_statements));return{suggestions:f,columnsWithSuggestions:g}}var x=e.i(635494);let h=(0,s.createContext)({isLoading:!1,isAvailable:!1,isEnabled:!1,columnsWithSuggestions:[],suggestions:[],openSheet:()=>{},getSuggestionsForColumn:()=>[],invalidate:async()=>{}});function f({children:e,schema:l,table:c}){let{data:u}=(0,x.useSelectedProjectQuery)(),{isIndexAdvisorAvailable:g,isIndexAdvisorEnabled:_}=(0,n.useIndexAdvisorStatus)(),y=(0,r.useQueryClient)(),[b,v]=(0,s.useState)(!1),[j,w]=(0,s.useState)(void 0),{data:S,isLoading:N}=function({projectRef:e,connectionString:t,schema:r,table:s},{enabled:a=!0,...n}={}){return(0,d.useQuery)({queryKey:o.databaseKeys.tableIndexAdvisor(e,r,s),queryFn:()=>p({projectRef:e,connectionString:t,schema:r,table:s}),enabled:a&&void 0!==e&&!!r&&!!s,retry:!1,staleTime:3e5,...n})}({projectRef:u?.ref,connectionString:u?.connectionString,schema:l,table:c},{enabled:_&&!!l&&!!c}),A=(0,s.useCallback)(e=>{w(e),v(!0)},[]),q=(0,s.useCallback)(()=>{v(!1),w(void 0)},[]),C=(0,s.useCallback)(e=>S?.suggestions?S.suggestions.filter(t=>t.index_statements.some(t=>{let r=t.matc