# Fix #25: ensure sensitive files and build artifacts are never committed

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment files — NEVER commit real credentials
backend/.env
frontend/.env
.env
.env.local
.env.*.local

# Build output
dist/
build/
.vite/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
